# ============================================================
# AI Option — Environment Configuration
# ============================================================
# Copy: cp .env.example .env

# ============ Deployer ============
DEPLOYER_PRIVATE_KEY=

# ============ RPC URLs ============
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
MAINNET_RPC_URL=https://eth.llamarpc.com

# ============ Etherscan ============
ETHERSCAN_API_KEY=

# ============ Provider: Multi-AI Fallback ============
# Set ANY ONE or more. Falls back automatically.
# If NONE set → returns UNCLEAR (not slashed, other providers resolve)

# Perplexity — best for factual bets (built-in web search)
PERPLEXITY_API_KEY=

# OpenRouter — unified gateway, many models
OPENROUTER_API_KEY=

# DeepSeek — cheap, strong reasoning
DEEPSEEK_API_KEY=

# Groq — fastest inference, generous free tier
GROQ_API_KEY=

# Anthropic — Claude direct
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o direct
OPENAI_API_KEY=

# Together AI — open models at scale
TOGETHER_API_KEY=

# Custom — any OpenAI-compatible endpoint
CUSTOM_AI_ENDPOINT=
CUSTOM_AI_KEY=
CUSTOM_AI_MODEL=

# ============ Ethereum ============
ETH_PRIVATE_KEY=
BET_CONTRACT_ADDRESS=
PROVIDER_REGISTRY_ADDRESS=
