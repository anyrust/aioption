# ============================================================
# AI Option — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============ Deployer ============
# Private key for deploying contracts (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# ============ RPC URLs ============
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
HOLESKY_RPC_URL=https://ethereum-holesky.publicnode.com
MAINNET_RPC_URL=https://eth.llamarpc.com

# ============ Etherscan ============
ETHERSCAN_API_KEY=

# ============ Provider (Docker Judge) ============
# Provider's OpenRouter API key
OPENROUTER_API_KEY=

# Provider's Ethereum private key (for submitting resolutions)
ETH_PRIVATE_KEY=

# Bet contract address to monitor (set after creating a bet)
BET_CONTRACT_ADDRESS=

# Provider Registry address
PROVIDER_REGISTRY_ADDRESS=

# TEE mode: "dstack" or "local"
TEE_MODE=local

# OpenRouter model (Claude, DeepSeek, GPT, etc.)
OPENROUTER_MODEL=anthropic/claude-opus-4-6